{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ProtocolWarden/PlatformManifest/schemas/private_manifest.schema.json",
  "title": "PrivateManifest",
  "description": "Private platform superset manifest. May contain multiple managed private projects, private implementation topology, and projection descriptors.",
  "type": "object",
  "required": ["manifest_kind", "manifest_version"],
  "additionalProperties": false,
  "properties": {
    "manifest_kind": { "type": "string", "const": "private" },
    "manifest_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "repos": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "#/$defs/RepoNode"
        }
      },
      "additionalProperties": false
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/Edge" }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/Relationship" }
    },
    "visibility_scope": {
      "type": "string",
      "enum": ["public", "private"],
      "description": "RepoGraph manifest-cognition scope (ADR 0002 P0.4). Private manifests declare 'private'."
    },
    "also_hosts": {
      "type": "array",
      "description": "Cross-private grants (ADR 0002 P0.4). Each entry names another private manifest and the specific repos this manifest is allowed to host cognition about.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["manifest", "repos"],
        "properties": {
          "manifest": { "type": "string", "minLength": 1 },
          "repos": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  },
  "$defs": {
    "Visibility": {
      "type": "string",
      "enum": ["public", "private", "internal", "restricted", "local"]
    },
    "ProjectionBehavior": {
      "type": "string",
      "enum": [
        "public_safe",
        "private_only",
        "local_only",
        "redact",
        "redacted_public_stub",
        "drop_from_public"
      ]
    },
    "EntityKind": {
      "type": "string",
      "enum": [
        "Repository",
        "Project",
        "ManagedProject",
        "ManagedRepository",
        "PublicRepository",
        "PrivateRepository",
        "ProtocolRepository",
        "ArtifactProducer",
        "DeploymentLayer",
        "ExecutionBackend",
        "Manifest",
        "Artifact",
        "Run",
        "Audit",
        "Evidence",
        "Binding",
        "VisibilityPolicy",
        "ProjectionRule",
        "RedactionRule",
        "MirrorRelationship",
        "SupersetRelationship"
      ]
    },
    "PlatformPlane": {
      "type": "string",
      "enum": [
        "documentation",
        "ontology",
        "topology",
        "topography",
        "governance",
        "control",
        "runtime",
        "utility"
      ]
    },
    "OwnerKind": {
      "type": "string",
      "enum": [
        "protocol",
        "control_plane",
        "manifest",
        "deployment",
        "governance",
        "managed_project",
        "utility",
        "documentation"
      ]
    },
    "RelationshipKind": {
      "type": "string",
      "enum": [
        "consumes_manifest",
        "publishes_projection",
        "reads_artifact",
        "writes_artifact",
        "reads_heartbeat",
        "subscribes_to_heartbeat",
        "dispatches_request",
        "poll_status",
        "indexes_output",
        "validates_output",
        "owns_schema",
        "implements_adapter",
        "invokes_runtime",
        "produces_artifact",
        "reports_to",
        "projects_to",
        "redacts_from",
        "implements",
        "documents",
        "orchestrates",
        "deploys",
        "hosts",
        "references_schema_from",
        "manages",
        "produces_artifacts_for",
        "consumes_manifest_from",
        "validates_with",
        "loads_plugin_from"
      ]
    },
    "RepoNode": {
      "type": "object",
      "required": ["canonical_name", "visibility"],
      "additionalProperties": false,
      "properties": {
        "canonical_name": { "type": "string", "minLength": 1 },
        "visibility": { "$ref": "#/$defs/Visibility" },
        "github_url": { "type": "string", "format": "uri" },
        "runtime_role": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/EntityKind" },
        "plane": { "$ref": "#/$defs/PlatformPlane" },
        "owner_kind": { "$ref": "#/$defs/OwnerKind" },
        "owner": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "projection_policy": { "type": "string", "minLength": 1 },
        "projection_behavior": { "$ref": "#/$defs/ProjectionBehavior" },
        "public_alias": { "type": "string", "minLength": 1 },
        "redaction_label": { "type": "string", "minLength": 1 },
        "private_binding_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "local_overlay_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "integer", "number", "boolean"]
          }
        },
        "context_lifecycle": { "$ref": "#/$defs/RepoContextLifecycleFlags" }
      }
    },
    "RepoContextLifecycleFlags": {
      "type": "object",
      "description": "Per-repo CL participation flags. See ADR 0002.",
      "additionalProperties": false,
      "properties": {
        "participates": { "type": "boolean" },
        "cognition_host": { "type": "boolean" },
        "manifest_scope_declared": { "type": "boolean" },
        "shim_only": { "type": "boolean" },
        "dispatcher_integration": { "type": "boolean" },
        "cli_provider": { "type": "boolean" },
        "schema_owner": { "type": "boolean" },
        "contextguard": { "type": "boolean" },
        "workspace_capsules": { "type": "boolean" }
      }
    },
    "Edge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "depends_on_contracts_from",
            "dispatches_to",
            "routes_through",
            "bundles_assets_from"
          ]
        }
      }
    },
    "Relationship": {
      "type": "object",
      "required": ["id", "source", "target", "kind", "visibility", "projection_behavior"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/RelationshipKind" },
        "visibility": { "$ref": "#/$defs/Visibility" },
        "projection_behavior": { "$ref": "#/$defs/ProjectionBehavior" },
        "policy_ref": { "type": "string", "minLength": 1 },
        "redaction_label": { "type": "string", "minLength": 1 },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "integer", "number", "boolean"]
          }
        }
      }
    }
  }
}
