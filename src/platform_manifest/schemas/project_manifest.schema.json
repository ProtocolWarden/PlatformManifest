{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Velascat/PlatformManifest/schemas/project_manifest.schema.json",
  "title": "ProjectManifest",
  "description": "Manifest for one project that uses the platform. May contain public or private nodes.",
  "type": "object",
  "required": ["manifest_kind", "manifest_version"],
  "additionalProperties": false,
  "properties": {
    "manifest_kind": {
      "type": "string",
      "const": "project"
    },
    "manifest_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "platform_manifest": {
      "type": "object",
      "required": ["name", "version_constraint"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version_constraint": { "type": "string", "minLength": 1 }
      }
    },
    "repos": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "#/$defs/ProjectRepoNode"
        }
      },
      "additionalProperties": false
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/Edge" }
    },
    "includes": {
      "type": "array",
      "items": { "$ref": "#/$defs/Include" },
      "description": "Sub-project manifests this manifest includes. Used by the multi-repo project shell pattern (one shell manifest references the project_manifest.yaml of each constituent project)."
    }
  },
  "$defs": {
    "Include": {
      "type": "object",
      "required": ["name", "project_manifest_path"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "description": "Human label for the included sub-project (informational)." },
        "project_manifest_path": { "type": "string", "minLength": 1, "description": "Path to the included project_manifest.yaml. Relative paths resolve against the including manifest's directory." }
      }
    },
    "ProjectRepoNode": {
      "type": "object",
      "required": ["canonical_name", "visibility"],
      "additionalProperties": false,
      "properties": {
        "canonical_name": { "type": "string", "minLength": 1 },
        "visibility": {
          "type": "string",
          "enum": ["public", "private"]
        },
        "legacy_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "github_url": { "type": "string", "format": "uri" },
        "runtime_role": { "type": "string", "minLength": 1 }
      }
    },
    "Edge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "depends_on_contracts_from",
            "dispatches_to",
            "routes_through",
            "bundles_assets_from"
          ]
        }
      }
    }
  }
}
