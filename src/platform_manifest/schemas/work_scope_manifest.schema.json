{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ProtocolWarden/PlatformManifest/schemas/work_scope_manifest.schema.json",
  "title": "WorkScopeManifest",
  "description": "Composes multiple ProjectManifests into one OperationsCenter work scope. Composition is explicit — only listed includes are loaded; no filesystem discovery. Added in PlatformManifest v0.9.0.",
  "type": "object",
  "required": ["manifest_kind", "manifest_version", "includes"],
  "additionalProperties": false,
  "properties": {
    "manifest_kind": {
      "type": "string",
      "const": "work_scope"
    },
    "manifest_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "platform_manifest": {
      "type": "object",
      "required": ["name", "version_constraint"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version_constraint": { "type": "string", "minLength": 1 }
      }
    },
    "includes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Include" },
      "description": "ProjectManifests this work scope composes. Order matters — earlier includes may be referenced by canonical name from later ones."
    },
    "repos": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "#/$defs/WorkScopeRepoNode"
        }
      },
      "additionalProperties": false,
      "description": "Optional. Work-scope-level repos rarely needed; usually empty."
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/Edge" },
      "description": "Cross-suite edges declared at the work-scope layer. These get Source.WORK_SCOPE provenance."
    }
  },
  "$defs": {
    "Include": {
      "type": "object",
      "required": ["name", "project_manifest_path"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "description": "Human label for the included project (informational)." },
        "project_manifest_path": { "type": "string", "minLength": 1, "description": "Path to the included project_manifest.yaml. Relative paths resolve against this work-scope manifest's directory." }
      }
    },
    "WorkScopeRepoNode": {
      "type": "object",
      "required": ["canonical_name", "visibility"],
      "additionalProperties": false,
      "properties": {
        "canonical_name": { "type": "string", "minLength": 1 },
        "visibility": {
          "type": "string",
          "enum": ["public", "private"]
        },
        "legacy_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "github_url": { "type": "string", "format": "uri" },
        "runtime_role": { "type": "string", "minLength": 1 }
      }
    },
    "Edge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "depends_on_contracts_from",
            "dispatches_to",
            "routes_through",
            "bundles_assets_from"
          ]
        }
      }
    }
  }
}
