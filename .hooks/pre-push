#!/usr/bin/env bash
# Custodian regression guard — pre-push hook.
set -e

repo_root="$(git rev-parse --show-toplevel)"
workspace_root="$(cd "$repo_root/.." && pwd)"

if [ -z "${REPOGRAPH_BOUNDARY_ARTIFACT_FILE:-}" ]; then
    shopt -s nullglob
    for candidate in \
        "$workspace_root"/*/dist/boundary_disclosure_artifact.json \
        "$workspace_root"/*/policy/boundary_disclosure_artifact.json
    do
        if [ -f "$candidate" ]; then
            export REPOGRAPH_BOUNDARY_ARTIFACT_FILE="$candidate"
            break
        fi
    done
    shopt -u nullglob
fi

if [ -z "${REPOGRAPH_BOUNDARY_ARTIFACT_FILE:-}" ] || [ ! -f "$REPOGRAPH_BOUNDARY_ARTIFACT_FILE" ]; then
    echo "[custodian-pre-push] missing REPOGRAPH_BOUNDARY_ARTIFACT_FILE; failing closed"
    echo "  Generate artifact from your private-manifest repo first:"
    echo "  python -m private_manifest.export_boundary_artifact --graph-root graph --out dist/boundary_disclosure_artifact.json"
    exit 1
fi

custodian_multi=""
if command -v custodian-multi >/dev/null 2>&1; then
    custodian_multi="$(command -v custodian-multi)"
fi
for candidate in \
    "$custodian_multi" \
    "$repo_root/.venv/bin/custodian-multi" \
    "$repo_root/.warehouse-venv/bin/custodian-multi" \
    "$workspace_root/Custodian/.venv/bin/custodian-multi"
do
    if [ -x "$candidate" ]; then
        custodian_multi="$candidate"
        break
    fi
done

if [ -z "$custodian_multi" ]; then
    echo "[custodian-pre-push] custodian-multi not found"
    echo "  install with: python -m pip install -e /home/dev/Documents/GitHub/Custodian"
    exit 1
fi

echo "[custodian-pre-push] boundary artifact: $REPOGRAPH_BOUNDARY_ARTIFACT_FILE"
echo "[custodian-pre-push] running audit guard..."
"$custodian_multi" --repos "$repo_root" --fail-on-findings --no-color

# --- reconciliation dashboard freshness gate (CL #22) -----------------------
# The committed status dashboard claims "Generated by `cl reconcile index`.
# Do not hand-edit." — enforce it. Local-only by necessity: the check needs
# the workspace clones + their worksheets, which CI doesn't have.
# Bootstrap-safe: missing `cl` warns and continues; a stale dashboard blocks.
status_md="$repo_root/docs/architecture/console-reconciliation-status.md"
manifest_yaml="$repo_root/src/platform_manifest/data/platform_manifest.yaml"
cl_bin=""
for candidate in \
    "$(command -v cl 2>/dev/null || true)" \
    "$workspace_root/ContextLifecycle/.venv/bin/cl" \
    "$workspace_root/ContextLifecycle/bin/cl"
do
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
        cl_bin="$candidate"
        break
    fi
done

if [ -z "$cl_bin" ]; then
    echo "[reconcile-pre-push] cl not found; skipping dashboard freshness check (warn-only)"
elif [ -f "$status_md" ]; then
    echo "[reconcile-pre-push] checking dashboard freshness..."
    if ! "$cl_bin" reconcile index --check \
        --clones-root "$workspace_root" \
        --manifest "$manifest_yaml" \
        --out "$status_md"; then
        echo "[reconcile-pre-push] dashboard is stale — regenerate, commit, re-push:"
        echo "  cl reconcile index --clones-root '$workspace_root' --manifest '$manifest_yaml' --out '$status_md'"
        exit 1
    fi
fi

# --- leaf-doc drift gate (ci-conventions PM↔Custodian) -----------------------
# docs/inject/ci-conventions.md is duplicated into Custodian (PM canonical).
# Each copy's trailer is repo-specific BY DESIGN; the convention BULLETS are
# the content that must not drift. Local-only (needs the sibling clone);
# missing clone skips, drifted bullets block.
leaf_pm="$repo_root/docs/inject/ci-conventions.md"
leaf_cust="$workspace_root/Custodian/docs/inject/ci-conventions.md"
if [ -f "$leaf_pm" ] && [ -f "$leaf_cust" ]; then
    if ! diff -q <(grep '^- ' "$leaf_pm") <(grep '^- ' "$leaf_cust") >/dev/null; then
        echo "[leaf-drift-pre-push] ci-conventions.md bullets drifted between PM and Custodian:"
        diff <(grep '^- ' "$leaf_pm") <(grep '^- ' "$leaf_cust") | head -10
        echo "  PM is canonical — sync the Custodian copy's bullets, then re-push."
        exit 1
    fi
    echo "[leaf-drift-pre-push] ci-conventions bullets in sync"
fi
